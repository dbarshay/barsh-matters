// Persisted OCR extraction result (from lib/ocr). Provider-agnostic and format-agnostic:
// stores full text + generic key/value pairs + tables, with NO assumption about document
// layout (a bill may be HCFA-1500, UB-04, a letterhead invoice, an itemized statement, etc.).
// Consumed by both intake paths (import-intake matter creation) and matter-document filing;
// `text` powers future content search (document-folder-structure.md enhancement #5).
model OcrExtraction {
  id String @id @default(cuid())

  // Source linkage — forward-compatible; the folder/document models are not built yet.
  sourceType          String  @default("adhoc") // import_intake | matter_document | payment_modal | adhoc
  matterId            Int?
  matterDisplayNumber String?
  clioDocumentId      String? // set once the underlying file is finalized/stored in Clio

  // File identity (sha256 enables dedupe / idempotency / linking to the stored file)
  fileName    String?
  contentType String?
  byteSize    Int?
  fileHash    String

  // Extraction result (matches the OcrExtractionResult shape in lib/ocr/types.ts)
  provider       String // azure-document-intelligence | stub | future vendors
  model          String // prebuilt-layout | prebuilt-read | future prebuilt/custom models
  mode           String // read | layout
  pageCount      Int    @default(0)
  meanConfidence Float?
  text           String // full OCR text (PHI) — Neon is HIPAA-covered under the DB BAA
  keyValues      Json // OcrKeyValue[]
  tables         Json? // OcrTable[] (optional; can be large)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matterId])
  @@index([matterDisplayNumber])
  @@index([fileHash])
  @@index([sourceType])
  @@index([clioDocumentId])
}

// A document FILED into the BM folder tree. BM-side metadata ONLY — the actual file lives flat in
// Clio (referenced by clioDocumentId); BM never creates Clio subfolders (see
// docs/document-folder-structure.md invariant). folderKey/titleKey are validated against the code
// taxonomy in lib/documents/folderTaxonomy.ts (server-side enforcement). One row per filing.
model FiledDocument {
  id String @id @default(cuid())

  // Filing target. `level` mirrors the folder's level. Matter-level rows sit on an individual BRL_
  // matter (matterId set); lawsuit-level rows sit on the lawsuit file (masterLawsuitId set). Exactly
  // one of matterId / masterLawsuitId is set per row.
  matterId            Int?
  masterLawsuitId     String?
  matterDisplayNumber String?
  level               String // "matter" | "lawsuit"

  // The stored file in Clio (the vault). BM points at it; it never duplicates the bytes.
  clioDocumentId String
  fileName       String?
  contentType    String?
  fileHash       String? // sha256 of the bytes — links to OcrExtraction + exact-duplicate detection

  // BM organization (validated against the taxonomy; freehand only where the folder allows it).
  folderKey     String // e.g. "claim_documents.bills"
  titleKey      String // taxonomy title key, or FREEHAND_TITLE_KEY ("__freehand_other__")
  titleLabel    String // composed display label (may include prompt values + a (2)/(3) suffix)
  freehandTitle String? // operator-typed title when titleKey is the freehand sentinel
  fields        Json? // structured prompt values (dates, amounts, outcome, payment category, ...)

  // Provenance — where the document came IN from (source-agnostic filing pipeline).
  sourceType      String  @default("upload") // upload | email_attachment | template | scan
  ocrExtractionId String? // OCR record if the fields were OCR-prefilled (links by fileHash pre-Clio)

  // Lifecycle. Soft-delete = archived (admin); hard delete is Owner-only (handled in the delete path).
  status      String   @default("active") // active | archived
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([matterId])
  @@index([masterLawsuitId])
  @@index([matterDisplayNumber])
  @@index([folderKey])
  @@index([clioDocumentId])
  @@index([fileHash])
  @@index([status])
}

// ---------------------------------------------------------------------------------------------------
// OCR human-in-the-loop LEARNING (deterministic, auditable — no ML on PHI).
//
// Every filing records what the classifier SUGGESTED vs what the operator CHOSE. The rollup table
// aggregates the operator's choices per business entity (provider / carrier) so future uploads from a
// recognized sender can be biased toward the historically-correct folder/title. We store only
// business-entity keys (provider/insurer names) + folder/title — never patient identity — so the
// learning store stays PHI-light.
// ---------------------------------------------------------------------------------------------------

// One row per filing: the suggestion, the operator's final pick, and whether it was a correction.
model OcrFilingFeedback {
  id String @id @default(cuid())

  matterId        Int?
  masterLawsuitId String?
  fileName        String?
  fileHash        String?
  ocrExtractionId String?

  // What the classifier proposed (may be null when it had no confident suggestion).
  suggestedFolderKey  String?
  suggestedTitleKey   String?
  suggestedConfidence Float?

  // What the operator actually filed it as.
  chosenFolderKey String
  chosenTitleKey  String
  caseType        String? // no_fault | wc | arbitration (operator-selected)

  // Normalized business-entity keys the document matched (for the memory rollup). NOT patient PHI.
  providerKey String?
  insurerKey  String?

  wasCorrected Boolean @default(false) // chosen != suggested

  createdById String?
  createdAt   DateTime @default(now())

  @@index([providerKey])
  @@index([insurerKey])
  @@index([chosenFolderKey])
  @@index([wasCorrected])
  @@index([createdAt])
}

// Incremental rollup: per (entity, caseType) how often the operator filed to a given folder/title.
// getLearnedSuggestion reads the dominant (highest-count) row for a matched entity. Upserted on each
// filing so it improves continuously without any batch job.
model OcrEntityDefault {
  id String @id @default(cuid())

  entityType String // "provider" | "insurer"
  entityKey  String // normalized provider/insurer name
  caseType   String @default("") // "" = any; else no_fault | wc | arbitration

  folderKey String
  titleKey  String

  count      Int      @default(1)
  lastSeenAt DateTime @default(now())

  @@unique([entityType, entityKey, caseType, folderKey, titleKey])
  @@index([entityType, entityKey])
}

// --- Legacy-document migration manifest (LawSpades → Azure) ---
// These were originally created as raw-SQL tables by scripts/atlas-migration. Registering them as Prisma
// models brings them under the backup/restore + schema tooling so they STOP getting dropped and are backed
// up (the manifest is the only link between hash-named Azure blobs and their cases — losing it is fatal).
// Field shapes mirror the pipeline's CREATE TABLE exactly (see scripts/atlas-migration/ledger.ts).
model LegacyCase {
  caseId    String   @id @map("case_id")
  status    String   @default("pending") // pending | listed | done | error
  priority  Int      @default(0) // higher = processed first (open matters)
  fileCount Int?     @map("file_count")
  doneCount Int      @default(0) @map("done_count")
  error     String?
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("legacy_case")
}

model LegacyDocument {
  id          BigInt   @id @default(autoincrement())
  caseId      String   @map("case_id")
  atlasFileId BigInt   @map("atlas_file_id")
  folderPath  String?  @map("folder_path")
  fileName    String   @map("file_name")
  byteSize    BigInt?  @map("byte_size")
  sha256      String?
  blobKey     String?  @map("blob_key")
  status      String   @default("pending") // pending | stored | error
  error       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([caseId, atlasFileId])
  @@index([caseId])
  @@index([status])
  @@index([sha256])
  @@map("legacy_document")
}

