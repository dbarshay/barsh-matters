generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model LawsuitSequenceCounter {
  id           Int      @id @default(autoincrement())
  year         Int
  month        Int
  lastSequence Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([year, month], name: "year_month")
}

// Year-scoped counter for individual matter display numbers: BRL_{YYYY}{seq}, seq resets each
// calendar year. Mirrors LawsuitSequenceCounter. Batch-allocated (increment by N) in lib/matterNumbering.ts.
model MatterSequenceCounter {
  id           Int      @id @default(autoincrement())
  year         Int      @unique
  lastSequence Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Global monotonic generator for the ClaimIndex.matter_id integer PK for LOCALLY-minted matters.
// Singleton row (id = 1). The allocator keeps lastId above MAX(existing ClaimIndex.matter_id) so
// new local ids never collide with legacy Clio-era matter ids. Batch-allocated.
model MatterIdCounter {
  id        Int      @id
  lastId    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Import batch audit + reversibility (all spreadsheet imports). Full per-row record; UI shows a
// summary line by default (drill-down to rows). Guarded undo removes only UNTOUCHED created matters.
// Reusable column-mapping template for the generic "other spreadsheet" importer. `mapping` maps each
// BM field -> source column header; `fixed` holds operator-picked single values (e.g. a provider or
// case type applied to the whole file). Owner-managed; keyed by name.
model ImportMapping {
  id        String   @id @default(cuid())
  name      String   @unique
  source    String   @default("other")
  mapping   Json // { bmField: "Source Column Header", ... }
  fixed     Json? // { providerEntityId?, caseType?, ... }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source])
}

// Carisk Management Report: persistent tracker of open "Saved Incomplete" bills, keyed by CIC#. A row
// is added/kept while the bill keeps arriving as Saved Incomplete; it is marked `removed` (graduated)
// when the same CIC# later arrives as a Carrier Submission (creating a matter). Weekly email digests
// the `open` rows.
model CariskManagementReportItem {
  id              String   @id @default(cuid())
  cicNumber       String   @unique
  patientName     String?
  providerName    String? // raw FacilityName
  carrierName     String? // raw CarrierName
  dosStart        String?
  dosEnd          String?
  claimAmount     Float?
  statusDate      String?
  rejectionDetail String? // HTML-stripped StatusNotes
  status          String   @default("open") // open | removed
  firstSeen       DateTime @default(now())
  lastSeen        DateTime @default(now())
  lastBatchId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([lastSeen])
}

model ImportBatch {
  id            String   @id @default(cuid())
  source        String // "dow" | "carisk" | "manual" | "other"
  sourceFile    String?
  actorName     String?
  actorEmail    String?
  status        String   @default("committed") // committed | undone
  totalRows     Int      @default(0)
  createdCount  Int      @default(0)
  rejectedCount Int      @default(0)
  reportCount   Int      @default(0)
  ignoredCount  Int      @default(0)
  details       Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rows ImportRow[]

  @@index([source])
  @@index([status])
  @@index([createdAt])
}

model ImportRow {
  id          String   @id @default(cuid())
  batchId     String
  rowIndex    Int
  outcome     String // created | rejected | to_report | ignored | duplicate | held
  reason      String?
  matterId    Int?
  fingerprint String?
  // Reconcile support (held rows): persisted staged payload + sub-reason + review lifecycle.
  holdReason   String? // carrier_unmatched | patient_ambiguous | data_quality
  reviewStatus String? // open | ready | committed | dismissed  (held rows only)
  staged       Json? // mapped/staged row data, so the matter can be created in-place after fixing
  resolution   Json? // operator decisions, e.g. { patient: "link"|"new", patientId?: string }
  createdAt   DateTime @default(now())

  batch ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([matterId])
  @@index([outcome])
  @@index([holdReason])
  @@index([reviewStatus])
}

// Reusable PATIENT master — one record per injured person, linked across all their matters.
// Identity resolution (lib/patientResolution.ts): fuzzy suggest-and-confirm, never auto-link on a
// fuzzy name; new patients auto-create when there is no match (patient is the sole auto-create
// exception to the owner-managed registry rule).
model Patient {
  id             String   @id @default(cuid())
  name           String // canonical "First Last"
  normalizedName String // lowercase/stripped match key
  source         String   @default("import")
  // Whether this patient may be a match target for FUTURE imports. false = quarantined (bulk-only):
  // pre-2025 patients from the one-time NF bulk load are recorded for history but never linked/merged
  // by later imports (an 18+ month gap makes a legit re-match unlikely; excluding them avoids old
  // misspellings creating false merges). resolvePatient filters to matchable:true. Default true keeps
  // all existing/live patients matchable. See docs/RESUME-HERE.md "PRE-2025 QUARANTINE".
  matchable      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  matters ClaimIndex[]

  @@index([normalizedName])
  @@index([name])
  @@index([matchable])
}

model Lawsuit {
  id                          Int       @id @default(autoincrement())
  masterLawsuitId             String    @unique
  oldLawsuitNumber            String? // legacy aggregated file number "445-PKTYY-NNNN" (migration; retired after cutover)
  claimNumber                 String?
  lawsuitMatters              String
  sharedFolderPath            String
  venue                       String?
  venueSelection              String?
  venueOther                  String?
  indexAaaNumber              String?
  lawsuitNotes                String?
  lawsuitOptions              Json?
  amountSoughtMode            String    @default("balance_presuit")
  amountSought                Float?
  customAmountSought          Float?
  amountSoughtBreakdown       Json?
  clioMasterMatterId          Int?
  clioMasterDisplayNumber     String?
  clioMasterMatterDescription String?
  clioMasterMappedAt          DateTime?
  clioMasterMappingSource     String?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  @@index([clioMasterMatterId])
  @@index([clioMasterDisplayNumber])
  @@index([oldLawsuitNumber])
}

model ClioToken {
  id           Int       @id @default(1)
  accessToken  String
  refreshToken String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tokenType    String    @default("bearer")
  expiresAt    DateTime?
}

model ClaimIndex {
  matter_id               Int     @id
  display_number          String?
  old_matter_number       String? // legacy paper file number "445YY-NNNNNNNNN" (migration; retired after cutover)
  description             String?
  claim_number_raw        String?
  claim_number_normalized String?
  patient_name            String?
  client_name             String?
  insurer_name            String?
  claim_amount            Float?
  settled_amount          Float?

  settled_with           String?
  allocated_settlement   Float?
  interest_amount        Float?
  principal_fee          Float?
  interest_fee           Float?
  total_fee              Float?
  provider_net           Float?
  provider_principal_net Float?
  provider_interest_net  Float?
  overdue_days           Float?
  payment_amount         Float?
  balance_amount         Float?
  bill_number            String?
  dos_start              String?
  dos_end                String?
  denial_reason          String?
  service_type           String?
  policy_number          String?
  date_of_loss           String?
  payment_voluntary      Float?
  balance_presuit        Float?
  master_lawsuit_id      String?
  status                 String?
  close_reason           String?
  final_status           String?
  raw_json               String?
  indexed_at             DateTime @default(now())
  matter_stage_name      String?
  index_aaa_number       String?
  patient_insurer        String?
  patient_provider       String?
  provider_name          String?
  treating_provider      String?

  // --- Import fields (Carisk / Dow data dictionaries). Dates stored as strings per table convention. ---
  cic_number                 String? @unique // Carisk bill-unique key (hard dedup); null for non-Carisk
  case_type                  String? // "Workers Compensation" | "No-Fault"
  status_notes               String? // cleaned payer status message (HTML stripped)
  status_date                String? // most recent status update
  date_bill_submitted        String? // date Carisk sent billing to insurer (SubmittedDate)
  provider_tin               String? // provider Tax ID / EIN, normalized XX-XXXXXXX
  treating_physician_npi     String?
  treating_physician_license String?
  place_of_service_address   String?
  place_of_service_address2  String?
  place_of_service_city      String?
  place_of_service_state     String?
  place_of_service_zip       String?
  carisk_operator            String?
  fingerprint                String? // Dow/manual dedup fingerprint (soft key) for cross-import matching
  patient_id                 String?
  patient                    Patient? @relation(fields: [patient_id], references: [id])

  // Batch tag for one-time bulk loads (e.g. "nf-legacy"). null = a normal/live matter. Drives the
  // display-only "-legacy" suffix (never mutate display_number itself — it's parsed by strict regexes
  // in lib/clioStoragePlan.ts). See lib/matterNumbering.ts formatMatterDisplayLabel + docs/legacy-import-marking-spec.md.
  import_batch               String?

  @@index([case_type])
  @@index([import_batch])
  @@index([old_matter_number])
  @@index([fingerprint])
  @@index([patient_id])
  @@index([claim_number_normalized])
  @@index([patient_name])
  @@index([provider_name])
  @@index([insurer_name])
  @@index([patient_provider])
  @@index([patient_insurer])
  @@index([master_lawsuit_id])
  @@index([index_aaa_number])
  @@index([close_reason])
  @@index([final_status])
  @@index([matter_stage_name])
  @@index([status])
  @@index([denial_reason])
  @@index([service_type])
  @@index([treating_provider])
}

